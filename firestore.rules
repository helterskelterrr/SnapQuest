rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'aqila@gmail.com';
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    // ── Users ────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isLoggedIn();
      // Owner can create their own doc; admin can create any (e.g. seed dummy users)
      allow create: if isLoggedIn() &&
                       (request.auth.uid == userId || isAdmin());
      // Owner can update their own doc; any logged-in user can update XP/points fields
      // (needed for vote transactions that award XP to submission owners)
      allow update: if isLoggedIn() &&
                       (request.auth.uid == userId || isAdmin() ||
                        // Allow updating only XP-related fields (for vote rewards)
                        (request.resource.data.diff(resource.data).affectedKeys()
                          .hasOnly(['total_xp', 'weekly_points'])));
      allow delete: if isAdmin();
    }

    // ── Challenges ───────────────────────────────────────────────
    match /challenges/{challengeId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    // ── Submissions ──────────────────────────────────────────────
    match /submissions/{submissionId} {
      allow read: if isLoggedIn();
      // User can create their own; admin can create any (e.g. seed dummy submissions)
      allow create: if isLoggedIn() &&
                       (request.resource.data.user_id == request.auth.uid || isAdmin());
      allow update: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // ── Votes ────────────────────────────────────────────────────
    match /votes/{voteId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      // Allow voter to delete their own vote (voteId = voterId_submissionId)
      allow delete: if isLoggedIn() || isAdmin();
    }

    // ── Reports ──────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow delete: if isAdmin();
    }

    // ── Notifications ─────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read, update, delete: if isLoggedIn() &&
                                     request.auth.uid == resource.data.recipient_id;
      allow create: if isLoggedIn();
    }

    // ── Comments ──────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if isLoggedIn();
      // Only the authenticated user can create their own comment
      allow create: if isLoggedIn() &&
                       request.resource.data.user_id == request.auth.uid;
      // Only comment owner or admin can delete
      allow delete: if isLoggedIn() &&
                       (request.auth.uid == resource.data.user_id || isAdmin());
      allow update: if isAdmin();
    }
  }
}