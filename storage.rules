rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Avatars: owner can read/write their own
    match /avatars/{userId}.jpg {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Submissions: any logged-in user can upload under their own userId prefix
    match /submissions/{challengeId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
                      fileName.matches(request.auth.uid + '_[0-9]+\\.jpg');
    }
  }
}